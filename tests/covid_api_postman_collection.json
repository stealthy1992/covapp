    {
      "name": "Get reports for a particular state for a particular day",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('This will test all the combinations of the response data', () => {",
              "",
              "    const jsonData = pm.response.json();",
              "    console.log(jsonData.data.length);",
              "    pm.expect(jsonData.data.length).to.not.equal(0);",
              "    // if (!jsonData.data || jsonData.data.length === 0) {",
              "    //     console.log(\"No data found, skipping further tests.\");",
              "    //     return; // stops execution of this test block",
              "    // }",
              "    if(jsonData.data.length > 0){",
              "",
              "        const data = jsonData.data[0]",
              "",
              "    pm.test('This will test the type of values that need to be a number', () => {",
              "        ",
              "        pm.expect([",
              "        data.confirmed,",
              "        data.deaths,",
              "        data.recovered,",
              "        data.confirmed_diff,",
              "        data.deaths_diff,",
              "        data.recovered_diff,",
              "        data.active,",
              "        data.active_diff,",
              "        data.fatality_rate,",
              "",
              "    ].every(v => typeof v === \"number\")).to.be.true;",
              "    })",
              "",
              "",
              "",
              "    pm.test('This will validate the date format', () => {",
              "        // console.log(jsonData.data)",
              "        pm.expect(data.date).to.match(/^\\d{4}-\\d{2}-\\d{2}$/);",
              "    })",
              "",
              "    pm.test('This will test if the region object exists in the response', () => {",
              "        pm.expect(data.region).to.be.an('object');",
              "        pm.expect(data.region).to.have.property('cities')",
              "        pm.expect(data.region.cities).to.be.an('array');",
              "        pm.expect(data.region.cities.length).to.equal(1);",
              "    })",
              "",
              "    pm.test('This will test that the city in the filter has lesser number of deaths and confirmed cases than the state in which the city is located', () => {",
              "",
              "        pm.expect(data.deaths).to.be.greaterThan(data.region.cities[0].deaths);",
              "        pm.expect(data.confirmed).to.be.greaterThan(data.region.cities[0].confirmed);",
              "        pm.expect(data.last_update).to.be.equal(data.region.cities[0].last_update);",
              "    })",
              "",
              "",
              "    }",
              "    ",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
