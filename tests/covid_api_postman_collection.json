    {
      "name": "Get reports for a particular state for a particular day",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "",
              "pm.test(\"Invalid Scenario: Fatality rate is 0 but deaths are recorded\", function () {",
              "    const responseJson = pm.response.json();",
              "    const data = responseJson.data;",
              "",
              "    let invalidRecords = [];",
              "",
              "    data.forEach(function (record) {",
              "        if (record.fatality_rate === 0 && record.deaths > 0) {",
              "            const province = record.region && record.region.province ? record.region.province : \"Unknown\";",
              "            invalidRecords.push(`Invalid data: ${province} has ${record.deaths} deaths but fatality rate is 0`);",
              "        }",
              "    });",
              "",
              "    if (invalidRecords.length > 0) {",
              "        pm.expect.fail(invalidRecords.join(\"; \"));",
              "    } else {",
              "        pm.expect(invalidRecords.length).to.eql(0, \"No invalid scenarios found: fatality rate is consistent with recorded deaths\");",
              "    }",
              "});",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
