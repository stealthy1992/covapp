              "pm.test('This will test the province/state retrieval', () => {",
              "    const province = [];",
              "    const jsonData = pm.response.json();",
              "    console.log(jsonData.data.length);",
              "    pm.expect(jsonData.data.length).to.be.greaterThan(0);",
              "    // pm.expect(jsonData.data[0].name).to.be.equal(\"Taiwan\")",
              "    jsonData.data.forEach((entry) => {",
              "        pm.expect(entry.name).be.be.equal(\"Taiwan\");",
              "        province.push(entry.province); ",
              "    })",
              "    console.log('Provinces are folowing:\\n', province)",
