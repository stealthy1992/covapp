      "name": "Get regions",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('printing the data', () => {",
              "    const jsonData = pm.response.json();",
              "    jsonData.data.forEach((item) => {",
              "        pm.expect(item).to.have.property('name');",
              "        pm.expect(item).to.have.property('iso');",
              "        pm.expect(item.name).to.be.not.empty;",
              "        pm.expect(item.iso).to.be.not.empty;",
              "        ",
